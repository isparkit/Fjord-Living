    "custom_faq_DMQerW": {
      "type": "custom-faq",
      "blocks": {
        "faq_xF6QJm": {
          "type": "faq",
          "settings": {
            "question": "Kan SmartScrub bruges udendørs?",
            "answer": "Ja, SmartScrub er perfekt til både indendørs og udendørs brug. Ude kan den for eksempel tage sig af altan- og terrassegulve, samt få grillristen og vinduer til at skinne."
          }
        },
        "faq_LTdqJc": {
          "type": "faq",
          "settings": {
            "question": "Kan man købe nye børstehoveder til sin SmartScrub?",
            "answer": "Skriv til os på info@fjordliving.dk og hvilke hoveder du har brug for, og vi finder ud af noget."
          }
        },
        "faq_8VwCd7": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Hvorfor vælge Fjordliving SmartRack?",
            "answer": "SmartRack er skabt med tanke på kvalitet, funktion og et design, der passer ind i hverdagen. Vi har nøje udvalgt materialer, testet løsninger og skabt et tørrestativ, der både holder og ser godt ud.\nKun hos fjordliving.dk finder du det originale SmartRack lavet med 1. klassesorteret bøgetræ, flot finish og små detaljer, der gør forskellen."
          }
        },
        "faq_iWHre8": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Jeg er glad for mit stativ – kan jeg sende jer et billede til inspiration?",
            "answer": "Ja, meget gerne! Vi elsker at se autentiske billeder af, hvordan SmartRack bliver brugt hjemme hos jer. Vi samler billeder fra vores kunder og viser dem som inspiration. Det er altid fantastisk at se, hvordan stativet passer ind og bruges i virkeligheden rundt omkring i danske hjem 🧺✨\n\nBilleder kan sendes til info@fjordliving.dk"
          }
        },
        "faq_LBBfyU": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Jeg vil give det som gave i weekenden. Kan det nå frem inden da?",
            "answer": "GLS leverer typisk fra dag til dag, men vi anbefaler at forvente 1-3 hverdage. DAO leverer normalt inden for 1-4 dage. Du vælger selv fragtfirma ved checkout."
          }
        },
        "faq_3DRxfF": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Kan jeg justere antallet af arme på SmartRack?",
            "answer": "Ja, SmartRack er designet med fleksibilitet for øje. Du kan nemt justere antallet af arme i overensstemmelse med dine tørrebehov og pladsbegrænsninger."
          }
        },
        "faq_tGbiDH": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Bør man tørre tøj indenfor?",
            "answer": "✅ Om vinteren anbefales det faktisk i mange boliger sammen med udluftning, da luften er meget tør. Tørring af tøj kan hjælpe med at beskytte trægulve, møbler og slimhinder mod udtørring.\n\n✅ Om sommeren kan du stadig tørre tøj inde, men husk at lufte godt ud, så du undgår for høj luftfugtighed.\n\nSmartRack er udviklet til at passe ind i hjemmet – og gør det nemt at tørre tøj med stil, uden rod og uden store metalstativer midt i stuen.\n\n🌀 God ventilation = sundt indeklima."
          }
        },
        "faq_mLptFG": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Hvor meget fylder stativet?",
            "answer": "SmartRack er designet til at være både pladsbesparende og funktionel:\n\nSlået sammen: Højde 70 cm, diameter 15 cm – nem at opbevare i hjørner, skabe eller bag en dør\n\nSlået ud:  Højde 121 cm, diameter 110 cm – giver rigelig tørreplads uden at fylde unødigt i rummet."
          }
        },
        "faq_TKRRbj": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Hvordan får jeg benene til at blive inde i stativet?",
            "answer": "Benene kan føres ind som vist <a href=\"https://cdn.shopify.com/videos/c/o/v/25bd07beb47747cd8ad0db410d7b682b.mov\" target=\"_blank\" rel=\"noopener noreferrer\">her</a>.\n\nFoden har en kliklås. Når den er klikket i, vil benene blive inde i stativet. \nNår den er klikket ud kan benene føres ud ud. Se eksempel video <a href=\"https://cdn.shopify.com/videos/c/o/v/c2523b7396f7449583253b0ca890e788.mov\" target=\"_blank\" rel=\"noopener noreferrer\">her</a>."
          }
        },
        "faq_kknTFX": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Kan SmartRack bruges udendørs?",
            "answer": "Ja, SmartRack er designet til både indendørs og udendørs brug. Dets holdbare konstruktion og lakering gør det velegnet til at modstå forskellige vejrforhold."
          }
        },
        "faq_c9ckVE": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Kan jeg tørre kjoler på stativet?",
            "answer": "Stativet har en højde på 121 cm, når det er slået ud, hvilket ofte er tilstrækkeligt til, at kjoler kan hænge, så de ikke rører gulvet. Alternativt kan kjolerne foldes over en af stativets arme."
          }
        },
        "faq_DCnk4h": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Hvad vejer SmartRack?",
            "answer": "Med sine 4.2kg og solide cylinderbase står smartrack stabilt."
          }
        }
      },
