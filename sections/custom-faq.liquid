{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Spørgsmål & svar"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Custom FAQ Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
    margin-top: 30px;
  }
  .faq-item {
    text-align: left;
    border-bottom: 1px solid #ddd;
    padding: 10px 0;
  }
  .faq-question {
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
  }
  .faq-answer {
    display: none;
    padding-top: 8px;
  }
  .faq-item.active .faq-answer {
    display: block;
  }
{% endstylesheet %}

<section
  class="faq-section section-{{ section.id }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="faq-subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="faq-grid">
      {% assign half = section.blocks.size | divided_by: 2 | ceil %}
      <div class="faq-left">
        {% for block in section.blocks limit: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question">
              {{ block.settings.question }}
              <span>+</span>
            </div>
            <div class="faq-answer">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>
      <div class="faq-right">
        {% for block in section.blocks offset: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question">
              {{ block.settings.question }}
              <span>+</span>
            </div>
            <div class="faq-answer">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-question').forEach((q) => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('active');
      });
    });
  });
</script>
