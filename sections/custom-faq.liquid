{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.40 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.40 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .faq-section {
    background-color: #ffffff;
  }
  .faq-section .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
    margin-top: 30px;
  }
   .faq-section .faq-item {
    text-align: left;
    border: 1px solid #885f41;
    padding: 10px 15px;
    margin-bottom: 20px;
    border-radius: 8px;
  }
   .faq-section .faq-question {
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0px;
    color: #000000;
    display: flex;
    justify-content: space-between;
  }
   .faq-section .faq-answer {
    display: none;
    padding-top: 8px;
    color: #fff;
    line-height: normal;
  }
   .faq-section .faq-item.active .faq-answer {
    display: block;
  }

  .faq-section h2 {
    text-align: center;
    font-family: 'Quicksand' !important;
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0px;
    color: #000000;
    padding-bottom: 20px;
  }
   .faq-section .faq-subheading p {
    font-weight: 400;
    text-align: center;
    max-width: 533px;
    margin: 0 auto;
    letter-spacing: 0px;
    line-height: normal;
    color: #000000;
  }

  @media (max-width: 767px) {
     .faq-section .faq-grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section
  class="faq-section section-{{ section.id }} section-{{ section.id }}-padding"
>
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="faq-subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="faq-grid">
      {% assign half = section.blocks.size | divided_by: 2 | ceil %}
      <div class="faq-left">
        {% for block in section.blocks limit: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question p">
              {{ block.settings.question }}
              <span>+</span>
            </div>
            <div class="faq-answer p">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>
      <div class="faq-right">
        {% for block in section.blocks offset: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question">
              {{ block.settings.question }}
              <span>+</span>
            </div>
            <div class="faq-answer">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-question').forEach((q) => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Spørgsmål & svar"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Custom FAQ Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
