{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.40 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.40 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .faq-section {
    background-color: #ffffff;
  }
  .faq-section .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
    margin-top: 30px;
  }
  .faq-section .faq-item {
    text-align: left;
    border: 1px solid #885f41;
    padding: 10px 15px;
    margin-bottom: 20px;
    border-radius: 8px;
  }
  .faq-section .faq-question {
    font-weight: 700;
    color: #000000;
    display: flex;
    justify-content: space-between;
    cursor: pointer;
  }
  .faq-section .faq-answer {
    display: none;
    padding-top: 8px;
    color: #000;
  }
  .faq-section h2 {
    text-align: center;
    font-family: 'Quicksand' !important;
    font-weight: 700;
    color: #000000;
    padding-bottom: 20px;
  }
  .faq-section .faq-subheading p {
    font-weight: 400;
    text-align: center;
    max-width: 533px;
    margin: 0 auto;
    color: #000000;
  }
  @media (max-width:1024px) {
    .faq-section .faq-grid {
      gap: 20px 30px !important;
    }
  }
  @media (max-width: 767px) {
    .faq-section .faq-grid {
      grid-template-columns: 1fr;
      gap: 0px !important;
    }
  }
{%- endstyle -%}

<section class="faq-section section-{{ section.id }} section-{{ section.id }}-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="faq-subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="faq-grid">
      {% assign half = section.blocks.size | divided_by: 2 | ceil %}

      <div class="faq-left">
        {% for block in section.blocks limit: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question p">
              {{ block.settings.question }}
              <span>
                <!-- Plus -->
                <svg
                  class="plus-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 15 15"
                  fill="none"
                >
                  <path d="M6.08607 15V8.76024H0V6.05533H6.08607V0H8.91394V6.05533H15V8.76024H8.91394V15H6.08607Z" fill="black"/>
                </svg>
                <!-- Cross -->
                <svg
                  class="cross-icon"
                  style="display:none;"
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 15 15"
                  fill="none"
                >
                  <path d="M1 1L14 14M14 1L1 14" stroke="black" stroke-width="2"/>
                </svg>
              </span>
            </div>
            <div class="faq-answer p">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>

      <div class="faq-right">
        {% for block in section.blocks offset: half %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <div class="faq-question p">
              {{ block.settings.question }}
              <span>
                <!-- Plus -->
                <svg
                  class="plus-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 15 15"
                  fill="none"
                >
                  <path d="M6.08607 15V8.76024H0V6.05533H6.08607V0H8.91394V6.05533H15V8.76024H8.91394V15H6.08607Z" fill="black"/>
                </svg>
                <!-- Cross -->
                <svg
                  class="cross-icon"
                  style="display:none;"
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 15 15"
                  fill="none"
                >
                  <path d="M1 1L14 14M14 1L1 14" stroke="black" stroke-width="2"/>
                </svg>
              </span>
            </div>
            <div class="faq-answer p">{{ block.settings.answer }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-question').forEach((q) => {
      q.addEventListener('click', () => {
        const faqItem = q.closest('.faq-item');
        const answer = faqItem.querySelector('.faq-answer');
        const plus = q.querySelector('.plus-icon');
        const cross = q.querySelector('.cross-icon');

        if (answer.style.display === 'block') {
          // बंद करना
          answer.style.display = 'none';
          plus.style.display = 'inline-block';
          cross.style.display = 'none';
          faqItem.classList.remove('active');
        } else {
          // खोलना
          answer.style.display = 'block';
          plus.style.display = 'none';
          cross.style.display = 'inline-block';
          faqItem.classList.add('active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Spørgsmål & svar"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Custom FAQ Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
