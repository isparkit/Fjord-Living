{% schema %}
{
  "name": "Two Column Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "cus_class",
      "label": "Custom Class"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f3ef"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Velkommen Til"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FJORDLIVING"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Her kommer din beskrivelse tekst. Tilføj lidt om dit brand, produkter eller USP."
    },
    {
      "type": "image_picker",
      "id": "star_image",
      "label": "Star Image"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Se vores udvalg"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "Two Column Hero Section"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .two-col-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .two-col-hero .left {
    flex: 1;
  }
  .two-col-hero .right {
    flex: 1;
    text-align: center;
  }
  .fir-img-text .left a span,
  .sec-img-text .left a span {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0px;
    line-height: 1em;
    font-family: 'Quicksand' !important;
  }
  .fir-img-text .left a,
  .sec-img-text .left a {
    border: 1px solid #885f41;
    padding: 11px 25px 14px 25px;
    border-radius: 50px;
    background-color: #f2e2d7;
  }

  .fir-img-text .left span {
    font-size: 24px;
    font-weight: 600;
    line-height: 100%;
    letter-spacing: 0px;
    color: #000000;
  }

  /* second section */
  .sec-img-text .left h2 {
    font-size: 48px;
    font-weight: 700;
    font-family: 'Quicksand' !important;
    color: #000000;
    line-height: 100%;
    letter-spacing: 0px;
    padding-bottom: 30px;
  }
  .sec-img-text .left p {
    font-size: 22px;
    font-weight: 400;
    color: #000000;
    letter-spacing: 0px;
    margin-bottom: 51px;
  }
  @media (max-width: 767px) {
    .fir-img-text .left span {
      font-size: 18px;
    }
    .sec-img-text .left h2 {
      font-size: 24px;
    }
    .fir-img-text .two-col-hero h2 {
      font-size: 55px !important;
      margin-bottom: 0px;
    }

    .two-col-hero {
      flex-direction: column-reverse;
    }

    .two-col-hero .left img {
      padding-bottom: 30px;
    }
  }
{% endstylesheet %}

<section
  class="{{ section.settings.cus_class }}"
  style="
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    <div class="two-col-hero">
      <!-- Left Content -->
      <div class="left">
        {% if section.settings.subheading != blank %}
          <span>{{ section.settings.subheading }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.content != blank %}
          <p>{{ section.settings.content }}</p>
        {% endif %}

        {% if section.settings.star_image != blank %}
          <img src="{{ section.settings.star_image | img_url: 'master' }}" alt="Star Image">
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <div class="flex-alig">
            <a href="{{ section.settings.button_link }}">
              <span>{{ section.settings.button_text }}</span>
              <!-- SVG Icon after text -->
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <path d="M5 12h14M13 5l7 7-7 7"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        {% endif %}
      </div>

      <!-- Right Content -->
      <div class="right">
        {% if section.settings.right_image != blank %}
          <img src="{{ section.settings.right_image | img_url: 'master' }}" alt="Hero Image">
        {% endif %}
      </div>
    </div>
  </div>
</section>
