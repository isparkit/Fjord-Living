{% schema %}
{
  "name": "Two Column Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "cus_class",
      "label": "Custom Class"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f3ef"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Velkommen Til"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FJORDLIVING"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Her kommer din beskrivelse tekst. Tilføj lidt om dit brand, produkter eller USP."
    },
    {
      "type": "image_picker",
      "id": "star_image",
      "label": "Star Image"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Se vores udvalg"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "Two Column Hero Section"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .two-col-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .two-col-hero .left {
    flex: 1;
  }
  .two-col-hero .right {
    flex: 1;
    text-align: center;
  }
  .two-col-hero h2 {
    font-size: 42px;
    font-weight: bold;
    margin-bottom: 15px;
  }
  .two-col-hero p {
    margin-bottom: 20px;
  }
  .two-col-hero a {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 12px 24px;
    border-radius: 5px;
    text-decoration: none;
  }
{% endstylesheet %}

<section
  class="{{section.settings.cus_class}}"
  style="
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    <div class="two-col-hero">
      <!-- Left Content -->
      <div class="left">
        {% if section.settings.subheading != blank %}
          <span>{{ section.settings.subheading }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.content != blank %}
          <p>{{ section.settings.content }}</p>
        {% endif %}
        {% if section.settings.star_image != blank %}
          <img src="{{ section.settings.star_image |img_url: 'master'}}" alt="Hero Image">
        {% endif %}
        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
        {% endif %}
      </div>

      <!-- Right Image -->
      <div class="right">
        {% if section.settings.right_image != blank %}
          <img src="{{ section.settings.right_image |img_url: 'master'}}" alt="Hero Image">
        {% endif %}
      </div>
    </div>
  </div>
</section>