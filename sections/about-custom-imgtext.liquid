{% style %}
  .about-custom-section {
    padding: 60px 0;
  }

  .about-custom-section .about-container {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    justify-content: space-between;
  }

  .about-custom-section .about-left {
    flex: 1;
    position: relative;
  }

  .about-custom-section .about-heading {
    font-size: 40px;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .about-custom-section .about-text {
    max-height: 200px;
    overflow: hidden;
    transition: max-height 0.6s ease;
  }

  .about-custom-section .about-text.expanded {
    max-height: 2000px; /* big enough for full content */
  }

  .about-custom-section .read-more-btn {
    display: inline-block;
    margin-top: 15px;
    background: #333;
    color: #fff;
    padding: 8px 15px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    transition: 0.3s;
  }

  .about-custom-section .read-more-btn:hover {
    background: #555;
  }

  .about-custom-section .about-right {
    flex: 0 0 300px;
  }

  .about-custom-section .about-right img {
    max-width: 100%;
    border-radius: 10px;
  }
{% endstyle %}

<section class="about-custom-section" style="background-color: {{ section.settings.bg_color }}">
  <div class="container">
    <div class="about-container">
      <!-- LEFT CONTENT -->
      <div class="about-left">
        <h2 class="about-heading">{{ section.settings.heading }}</h2>
        <div class="about-text" id="aboutText-{{ section.id }}">
          {{ section.settings.content }}
        </div>
        <span class="read-more-btn" id="readMoreBtn-{{ section.id }}">Read More</span>
      </div>

      <!-- RIGHT IMAGE -->
      <div class="about-right">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url: '600x' }}" alt="About Image">
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var text = document.getElementById('aboutText-{{ section.id }}');
    var btn = document.getElementById('readMoreBtn-{{ section.id }}');

    btn.addEventListener('click', function () {
      text.classList.toggle('expanded');
      if (text.classList.contains('expanded')) {
        btn.innerText = 'Read Less';
      } else {
        btn.innerText = 'Read More';
      }
    });
  });
</script>

{% schema %}
{
  "name": "About Us Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbeee6"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Om os"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Left Side Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "About Us Custom"
    }
  ]
}
{% endschema %}
