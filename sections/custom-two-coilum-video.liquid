{% comment %}
  Two Column Content + Image Section
{% endcomment %}

<section
  id="section-{{ section.id }}"
  class="two-col-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="container">
    <div class="two-col-wrapper">
      <!-- Left Column -->
      <div class="two-col-left">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.content != blank %}
          <div class="rte">
            {{ section.settings.content }}
          </div>
        {% endif %}
      </div>

      <!-- Right Column -->
      <div class="two-col-right">
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true
          }}
        {% elsif section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}">
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Two Column Video",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Right Side Video"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Section"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .two-col-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    align-items: center;
  }
  .two-col-left h2 {
    font-size: 28px;
    margin-bottom: 15px;
  }
  .two-col-left .rte {
    font-size: 16px;
    line-height: 1.6;
  }
  .two-col-right img,
  .two-col-right video {
    width: 100%;
    border-radius: 10px;
    display: block;
  }
  @media (max-width: 767px) {
    .two-col-wrapper {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}
