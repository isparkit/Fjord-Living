{% style %}
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top | times: 0.40 | round: 0 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.40 | round: 0 }}px;
        }

        @media screen and (min-width: 750px) {
          .section-{{ section.id }}-padding {
            padding-top: {{ section.settings.padding_top }}px;
            padding-bottom: {{ section.settings.padding_bottom }}px;
          }
        }
        .two-col-section .rte p:not(:last-child) {
      margin-bottom: 15px;
  }

        .two-col-section {
          background-color: #fff;
        }

        .two-col-section .two-col-left .rte p {
          font-weight: 400;
          letter-spacing: 0px;
          line-height: normal;
          color: #000;
        }
        .two-col-section .two-col-left .rte p:not(:last-child){
          margin-bottom:15px;
        }
         .two-col-section .two-col-right{
           height:100%;
         }
        .two-col-section .two-col-right img,
        .two-col-section .two-col-right video {
          width: 100%;
          display: block;
          border-top-right-radius: 19px;
          border-bottom-right-radius: 19px;
        height: 100%;
        object-fit: cover;
    }

        .two-col-wrapper {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 30px;
          align-items: start;
          border: 1px solid #885f41;
          border-radius: 20px;
        }

        .two-col-section .two-col-left {
          padding: 40px;
        }

        .two-col-section .two-col-left h2 {
          font-weight: 700;
          line-height: normal;
          letter-spacing: 0px;
          color: #000;
          margin-bottom:30px;
        }

        .two-col-section .cu-list {
          margin-left: 25px;
        }

        .two-col-section .cu-list li {
          font-size: 18px;
          line-height: normal;
          letter-spacing: 0px;
          color: #000;
        }

        /*  Tablet Large (1024px and below) */
        @media (max-width: 1024px) {
          .two-col-section .two-col-left {
            padding: 20px;
          }
        }
      @media (min-width:768px) and (max-width:1440px){
        .two-col-left h2 {
         font-size:28px;

        }
      }
        /* Tablet Medium (989px and below) */
        @media (max-width: 989px) {
          .two-col-section .two-col-left {
            padding: 15px;
          }
        }

        /* Mobile (767px and below) */
        @media (max-width: 768px) {
          .two-col-section .two-col-wrapper {
             grid-template-columns:1fr;
             gap:0px;
          }
           .two-col-section .two-col-left .rte p {
            font-size: 16px;
          }
           .two-col-section .two-col-left h2 {
            font-size: 30px;
            margin-bottom:10px;
          }
           .two-col-section .two-col-left {
            padding: 20px;
          }
           .two-col-section .cu-list {
            margin-left: 10px;
          }
           .two-col-section .two-col-right img,  .two-col-section .two-col-right video{
            border-top-right-radius:0px;
            border-bottom-right-radius:0px;
            padding:0 15px  15px;
          }
          .two-col-left h2{
            margin-bottom:20px;
          }
        }
{% endstyle %}

<section
  id="section-{{ section.id }}"
  class="two-col-section section-{{ section.id }}-padding"
>
  <div class="container">
    <div class="two-col-wrapper">
      <!-- Left Column -->
      <div class="two-col-left">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.content != blank %}
          <div class="rte">
            {{ section.settings.content }}
          </div>
        {% endif %}
        <div class="cu-list">
          {% for block in section.blocks %}
            <li>{{ block.settings.list_text }}</li>
          {% endfor %}
        </div>
      </div>

      <!-- Right Column -->
      <div class="two-col-right">
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true
          }}
        {% elsif section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}">
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Two Column Video",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Right Side Video"
    }
  ],
  "blocks": [
    {
      "type": "list",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "list_text",
          "label": "Link list"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Section"
    }
  ]
}
{% endschema %}
