{% stylesheet %}
  .two-col-section {
    background-color: #ffff;
  }
  .two-col-left .rte p {
    padding-top: 30px;
    font-weight: 400;
    letter-spacing: 0px;
    line-height: normal;
    padding-bottom: 15px;
    color: #000;
  }
  .two-col-right img,
  .two-col-right video {
    width: 100%;
    display: block;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
  }
  .two-col-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    align-items: center;
    border: 1px solid #885f41;
    border-radius: 20px;
  }
  .two-col-left {
    padding-left: 40px;
  }
  .two-col-left h2 {
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0px;
    color: #000;
  }
  .cu-list {
    margin-left: 25px;
  }
  .cu-list li {
    font-size: 18px;
    line-height: normal;
    letter-spacing: 0px;
    color: #000;
  }
  @media (max-width: 1024px) {
    .two-col-left {
    }
  }
  @media (max-width: 767px) {
    .two-col-wrapper {
      grid-template-columns: 1fr;
      padding: 20px;
    }
    .two-col-left .rte p {
      font-size: 16px;
    }
    .two-col-left h2 {
      font-size: 30px;
    }
    .two-col-left {
      padding: 0px;
    }
    .cu-list {
      margin-left: 10px;
    }
  }
{% endstylesheet %}

<section
  id="section-{{ section.id }}"
  class="two-col-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="container">
    <div class="two-col-wrapper">
      <!-- Left Column -->
      <div class="two-col-left">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.content != blank %}
          <div class="rte">
            {{ section.settings.content }}
          </div>
        {% endif %}
        <div class="cu-list">
          {% for block in section.blocks %}
            <li>{{ block.settings.list_text }}</li>
          {% endfor %}
        </div>
      </div>

      <!-- Right Column -->
      <div class="two-col-right">
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true
          }}
        {% elsif section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}">
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Two Column Video",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Right Side Video"
    }
  ],
  "blocks": [
    {
      "type": "list",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "list_text",
          "label": "Link list"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Section"
    }
  ]
}
{% endschema %}
